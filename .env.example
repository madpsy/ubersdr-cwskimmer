# CW Skimmer Docker Configuration
# Copy this file to .env and customize the values

# Station Configuration
CALLSIGN=MM3NDH
NAME=Nathan
QTH=Dalgety Bay
SQUARE=IO86ha

# UberSDR Configuration
# Use container name when on same Docker network (ubersdr_sdr-network)
# Use localhost or IP address if running outside Docker network
UBERSDR_HOST=172.20.0.1
UBERSDR_PORT=8080

# Frequency Calibration
# Adjust if your SDR has a frequency offset (in PPM)
# Default: 1 (no calibration)
FREQ_CALIBRATION=1

# Callsign Validation
# Minimum quality level for decoded callsigns (0-2)
# 0 = Minimal (accept more spots, may include false decodes)
# 1 = Normal (balanced)
# 2 = Strict (only high-confidence decodes)
# Default: 0
MIN_QUALITY=0

# Sample Rate
# 192 = 192 kHz (default) - wider bandwidth per segment, higher CPU usage
# 96  = 96 kHz - half the CPU load, no loss of CW coverage for any band
SAMPLE_RATE=192

# Service Control
# Set to false to keep container running without starting CW Skimmer services
# Restart trigger watcher remains active for remote enable/disable
CWSKIMM_ENABLED=true

# Band Selection
# Set to true/false to enable/disable each band
# Note: SkimSrv has an 8-band limit per instance
# - If you enable ≤8 bands: Only instance 1 runs with those bands
# - If you enable 9-10 bands: Instance 1 gets first 8, instance 2 gets remaining
# Both instances always run, but instance 2 will be idle if ≤8 bands enabled
BAND_160M=true
BAND_80M=true
BAND_60M=true
BAND_40M=true
BAND_30M=true
BAND_20M=true
BAND_17M=true
BAND_15M=true
BAND_12M=true
BAND_10M=true
BAND_10M_BEACONS=true
